{
  "@context": [
    "https://linkedsoftwaredependencies.org/bundles/npm/@solid/community-server/^8.0.0/components/context.jsonld",
    "https://linkedsoftwaredependencies.org/bundles/npm/asynchronous-handlers/^1.0.0/components/context.jsonld",
    "https://linkedsoftwaredependencies.org/bundles/npm/@fedresda/server/^0.0.0/components/context.jsonld"
  ],
  "@graph": [
    {
      "@type": "Override",
      "overrideInstance": {
        "@id": "urn:solid-server:default:BaseHttpHandler"
      },
      "overrideSteps": [
        {
          "@type": "OverrideListInsertBefore",
          "overrideParameter": {
            "@id": "StatusWaterfallHandler:_handlers"
          },
          "overrideTarget": {
            "@id": "urn:solid-server:default:IdentityProviderHandler"
          },
          "overrideValue": {
            "@id": "urn:solid-server:default:ApiRouteHandler"
          }
        }
      ]
    },
    {
      "comment": "Routes all api related requests to the relevant handlers.",
      "@id": "urn:solid-server:default:ApiRouteHandler",
      "@type": "RouterHandler",
      "baseUrl": {
        "@id": "urn:solid-server:default:variable:baseUrl"
      },
      "targetExtractor": {
        "@id": "urn:solid-server:default:TargetExtractor"
      },
      "allowedPathNames": [
        "^/.api/.*"
      ],
      "handler": {
        "@id": "urn:solid-server:default:ApiHandler"
      }
    },
    {
      "comment": "Handles Api Route",
      "@id": "urn:solid-server:default:ApiHandler",
      "@type": "ApiHandler",
      "baseUrl": {
        "@id": "urn:solid-server:default:variable:baseUrl"
      },
      "rootFilePath": {
        "@id": "urn:solid-server:default:variable:rootFilePath"
      },
      "resourceStore": {
        "@id": "urn:solid-server:default:ResourceStore_Backend"
      }
    },
    {
      "@type": "Override",
      "overrideInstance": {
        "@id": "urn:solid-server-app-setup:default:CliExtractor"
      },
      "overrideSteps": [
        {
          "@type": "OverrideListInsertAt",
          "overrideParameter": {
            "@id": "YargsCliExtractor:_parameters"
          },
          "overrideTarget": 0,
          "overrideValue": {
            "@type": "YargsParameter",
            "name": "gitUri",
            "options": {
              "alias": "g",
              "requiresArg": true,
              "type": "string",
              "describe": "The URI for the git server. (example.com:2222)"
            }
          }
        }
      ]
    }
  ]
}