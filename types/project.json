{
  "name": "types",
  "$schema": "../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "types",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npm run build --workspace types"
      }
    },
    "build:ldo": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npm run build:ldo --workspace types"
      }
    }
  }
}
