PREFIX sar: <https://fedresda.setmeld.org/statistic-access-rule#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

# Represents the statistic access rule document as initialized by
# NemalineCsvResourceCreator and then edited/saved by StatisticAccessRuleView.
sar:StatisticAccessRuleDocumentShape {
  a [sar:StatisticAccessRule] ;
  sar:dataSchema xsd:string ;
  sar:hasStatisticPolicy @sar:StatisticPolicyShape *
}

sar:StatisticPolicyShape {
  sar:statisticName xsd:string
}
