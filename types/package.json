{
  "name": "@fedresda/types",
  "version": "0.0.0",
  "private": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./graphPath": {
      "types": "./dist/graphPath.d.ts",
      "default": "./dist/graphPath.js"
    }
  },
  "scripts": {
    "build:ldo": "ldo build --input _shapes --output _ldo",
    "build:ts": "tsc -p tsconfig.json",
    "build": "npm run build:ldo && npm run build:ts"
  },
  "devDependencies": {
    "@ldo/cli": "^1.0.0-alpha.38",
    "@types/shexj": "^2.1.7",
    "typescript": "^5.8.3"
  }
}
