# =============================================================================
# SetMeld Pod — Docker Compose Environment
# =============================================================================
# Copy this file to .env and edit values. All configuration is driven by this
# file; there are no hardcoded settings in scripts.
# =============================================================================

# -----------------------------------------------------------------------------
# General
# -----------------------------------------------------------------------------

# Public base URL of the application (no trailing slash).
# Examples: https://pod.mycompany.internal  or  http://localhost:3000
BASE_URL=http://localhost:3000

# Set to true when the app is behind a reverse proxy (F5, nginx, etc.) so that
# X-Forwarded-For and X-Forwarded-Proto are trusted. Required for correct
# redirects and client IP logging behind a proxy.
TRUST_PROXY=false

# Port the Node app listens on inside the container. Change only if you need to
# avoid a conflict; the default is 3000.
NODE_APP_PORT=3000

# -----------------------------------------------------------------------------
# Storage
# -----------------------------------------------------------------------------

# Host directory for persistent data (pods, integrations, triplestore data).
# Map to a local path or NFS mount. Must be readable/writable by the container.
# Example: /mnt/nfs/setmeld-data
HOST_DATA_DIR=./data

# -----------------------------------------------------------------------------
# Database (Triplestore)
# -----------------------------------------------------------------------------

# SPARQL endpoint URL for the triplestore.
# - Leave empty to use the bundled triplestore container (recommended for trials).
# - Set to your own endpoint to use an existing triplestore (e.g. corporate
#   Blazegraph or GraphDB). Example: http://triplestore.internal:9999/blazegraph/sparql
TRIPLESTORE_URL=

# -----------------------------------------------------------------------------
# Proxy & SSL (bundled Nginx)
# -----------------------------------------------------------------------------
# These apply only when the nginx service is enabled in docker-compose.yml.

# SSL mode for the bundled Nginx: none | custom | certbot
# - none:   HTTP only.
# - custom: HTTPS using your own certs (set SSL_CERT_PATH and SSL_KEY_PATH).
# - certbot: Let's Encrypt TLS (requires SSL_EMAIL and public reachability).
SSL_MODE=none

# For SSL_MODE=certbot: contact email for Let's Encrypt.
# SSL_EMAIL=

# For SSL_MODE=custom: paths inside the nginx container to cert and key.
# These are typically mounted from the host. Example: /etc/nginx/ssl/fullchain.pem
# SSL_CERT_PATH=/etc/nginx/ssl/fullchain.pem
# SSL_KEY_PATH=/etc/nginx/ssl/privkey.pem

# Hostname Nginx will use for server_name (e.g. pod.mycompany.internal).
# Defaults to hostname from BASE_URL if not set.
# NGINX_SERVER_NAME=

# Port Nginx listens on for HTTP (when SSL_MODE=none or for redirect when using TLS).
NGINX_HTTP_PORT=80

# Port Nginx listens on for HTTPS (when SSL_MODE=custom or certbot).
NGINX_HTTPS_PORT=443
