# SetMeld Pod deployment configuration
# Copy to config.env and edit values, then run ./deploy.sh up

# Public URL for this pod. Include protocol and no trailing slash.
# Example: https://pod.example.com
BASE_URL=http://localhost:3000

# true when traffic reaches the app through any reverse proxy.
TRUST_PROXY=false

# Where to store pod data on this host.
HOST_DATA_DIR=./data

# Expose node-app on this host port.
NODE_HOST_PORT=3000

# Triplestore mode:
# - bundled: deploy bundled Blazegraph container
# - external: use EXTERNAL_TRIPLESTORE_URL
TRIPLESTORE_MODE=bundled
EXTERNAL_TRIPLESTORE_URL=
TRIPLESTORE_HOST_PORT=9999

# Proxy mode:
# - nginx: deploy bundled nginx in front of node-app
# - external: do not run nginx (you will proxy to node-app yourself)
# - none: no proxy, clients connect directly to node-app port
PROXY_MODE=nginx

# TLS mode (only used when PROXY_MODE=nginx):
# - none: HTTP only
# - custom: use existing certificate files
# - letsencrypt: issue certificates with certbot
TLS_MODE=none

# Bundled nginx host ports.
HTTP_PORT=80
HTTPS_PORT=443

# Hostname for nginx server_name and letsencrypt domain.
# If empty, host from BASE_URL is used.
NGINX_SERVER_NAME=

# Required only when TLS_MODE=custom.
# Paths on the host to PEM files.
CUSTOM_CERT_FULLCHAIN=
CUSTOM_CERT_PRIVKEY=

# Required only when TLS_MODE=letsencrypt.
SSL_EMAIL=
