{
  "name": "@fedresda/ui",
  "main": "index.js",
  "version": "0.0.0",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev:ios": "expo start -c --ios",
    "dev:web": "concurrently \"npm run solid-server\" \"expo start -c --web\"",
    "dev:android": "expo start -c --android",
    "dev:server-hosted": "concurrently \"npm run solid-server\" \"npm run build:server:watch\"",
    "clean": "rm -rf .expo node_modules dist-standalone dist-server",
    "build:standalone": "expo export -p web --output-dir dist-standalone && node scripts/adjust-standalone-paths.js",
    "build:server": "EXPO_PUBLIC_IS_SERVER_HOSTED=true expo export -p web --output-dir dist-server && node scripts/adjust-server-paths.js",
    "build:server:watch": "npm run build && npx chokidar '**/*' -i 'dist-standalone/**' -i 'dist-server/**' -i 'node_modules/**' -c 'npm run build:server'",
    "build": "npm run build:standalone && npm run build:server"
  },
  "dependencies": {
    "@expo/metro-runtime": "~5.0.5",
    "@fedresda/types": "*",
    "@ldo/ldo": "^1.0.0-alpha.38",
    "@ldo/solid-react": "^1.0.0-alpha.38",
    "expo": "^53.0.9",
    "json-schema": "^0.4.0",
    "jsonld2graphobject": "^0.0.5",
    "linked-data-browser": "^0.0.8-alpha.5",
    "lucide-react-native": "^0.511.0",
    "nativewind": "^4.1.23",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-native": "0.79.2",
    "react-native-safe-area-context": "^5.4.0",
    "react-native-screens": "~4.10.0",
    "react-native-svg": "15.11.2",
    "react-native-web": "~0.20.0",
    "react-router": "^7.6.3"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@babel/plugin-syntax-import-meta": "^7.10.4",
    "@react-native-community/eslint-config": "^3.2.0",
    "@types/json-schema": "^7.0.15",
    "@types/jsonld": "^1.5.15",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/shexj": "^2.1.7",
    "chokidar-cli": "^3.0.0",
    "concurrently": "^9.1.2",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-prettier": "^5.4.1",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3"
  },
  "private": true
}
