{
  "name": "fedresda-monorepo",
  "version": "0.0.1-alpha.4",
  "description": "Fedresda Nx monorepo",
  "private": true,
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "nx": "nx",
    "graph": "nx graph",
    "dev": "nx run-many -t dev -p server,ui --parallel=2",
    "dev:server": "nx run server:dev",
    "dev:ui": "nx run ui:dev",
    "start:server": "nx run server:start",
    "build:server": "nx run server:build",
    "build:ui": "npm run build --workspace ui",
    "build:types": "npm run build --workspace types",
    "build": "nx run-many -t build -p types,server,ui --parallel=3",
    "test:schema-migration": "npm run test:schema-migration --workspace server",
    "deploy:package": "npm run build && node scripts/create-deploy-package.js",
    "version:get": "bash ./scripts/version.sh get",
    "version:set": "bash ./scripts/version.sh set",
    "version:bump": "bash ./scripts/version.sh bump"
  },
  "workspaces": [
    "server",
    "ui",
    "types"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SetMeld/fedresda-node.git"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/SetMeld/fedresda-node/issues"
  },
  "homepage": "https://github.com/SetMeld/fedresda-node#readme",
  "devDependencies": {
    "@tsconfig/node18": "^18.2.4",
    "@types/express": "^5.0.1",
    "@types/json-schema": "^7.0.15",
    "@types/multer": "^1.4.12",
    "@typescript-eslint/eslint-plugin": "^8.30.0",
    "@typescript-eslint/parser": "^8.30.0",
    "componentsjs-generator": "^4.3.0",
    "concurrently": "^9.1.2",
    "eslint": "^9.24.0",
    "eslint-config-prettier": "^10.1.2",
    "eslint-plugin-prettier": "^5.2.6",
    "nodemon": "^3.1.9",
    "prettier": "^3.5.3",
    "nx": "^20.8.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.3"
  },
  "dependencies": {
    "@fedresda/types": "*",
    "@ldo/ldo": "^1.0.0-alpha.44",
    "@ldo/connected-solid": "^1.0.0-alpha.44",
    "@solid/access-token-verifier": "^2.1.0",
    "@solid/community-server": "^8.0.0-alpha.0",
    "body-parser": "^2.2.0",
    "componentsjs": "^6.3.0",
    "express": "^5.1.0",
    "express-remove-route": "^1.0.0",
    "json-schema": "^0.4.0",
    "multer": "^1.4.5-lts.2",
    "yup": "^1.6.1"
  },
  "types": "./server/dist/index.d.ts"
}
