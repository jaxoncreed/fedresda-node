{# When ssl_enabled and not ssl_cert_ready: HTTP with ACME challenge only. #}
{# When ssl_enabled and ssl_cert_ready: HTTP redirect to HTTPS + HTTPS server. #}
{# Otherwise: HTTP only. #}

{# HTTP server (port 80): default when no SSL, or ACME + redirect when SSL #}
server {
    listen 0.0.0.0:{{ nginx_port }} default_server;
    listen [::]:{{ nginx_port }} default_server;
    server_name {{ base_url }};
    server_tokens off;

    access_log /var/log/nginx/setmeld_access.log;
    error_log /var/log/nginx/setmeld_error.log;

{% if ssl_enabled | default(false) %}
    # Let's Encrypt ACME challenge (Certbot writes to webroot/.well-known/acme-challenge/)
    location /.well-known/acme-challenge/ {
        alias /var/lib/letsencrypt/acme/.well-known/acme-challenge/;
    }
{% endif %}

{% if ssl_enabled | default(false) and ssl_cert_ready | default(false) %}
    location / {
        return 301 https://$host$request_uri;
    }
{% else %}
    # Proxy to SetMeld Pod web interface
    location / {
        proxy_pass http://127.0.0.1:3000;

        gzip off;
        proxy_redirect off;

        proxy_read_timeout 300;
        proxy_connect_timeout 300;

        proxy_http_version 1.1;

        proxy_set_header Host $http_host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
{% endif %}
}

{# HTTPS server (only when SSL cert is ready) #}
{% if ssl_enabled | default(false) and ssl_cert_ready | default(false) %}
server {
    listen 443 ssl default_server;
    listen [::]:443 ssl default_server;
    server_name {{ base_url }};
    server_tokens off;

    ssl_certificate /etc/letsencrypt/live/{{ base_url }}/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/{{ base_url }}/privkey.pem;
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers off;
    ssl_ciphers ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384;

    access_log /var/log/nginx/setmeld_access.log;
    error_log /var/log/nginx/setmeld_error.log;

    location / {
        proxy_pass http://127.0.0.1:3000;

        gzip off;
        proxy_redirect off;

        proxy_read_timeout 300;
        proxy_connect_timeout 300;

        proxy_http_version 1.1;

        proxy_set_header Host $http_host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
{% endif %}

# Catch-all for any other hostnames
server {
    listen 0.0.0.0:{{ nginx_port }};
    listen [::]:{{ nginx_port }};
    server_name _;
    server_tokens off;

    access_log /var/log/nginx/setmeld_access.log;
    error_log /var/log/nginx/setmeld_error.log;

    location / {
        proxy_pass http://127.0.0.1:3000;

        gzip off;
        proxy_redirect off;

        proxy_read_timeout 300;
        proxy_connect_timeout 300;

        proxy_http_version 1.1;

        proxy_set_header Host $http_host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
